# --- CardioProtect Extractor Environment ---
APP_NAME="CardioProtect Extractor (Local Llama3)"
APP_VERSION="3.0"

# Ollama Model (can switch to orca-mini:3b if RAM < 16GB)
OLLAMA_MODEL="llama3:8b"
OLLAMA_API_URL="http://localhost:11434/api/generate"

# Local paths (adjust as needed)
TEMPLATE_PATH="CardioProtect_MetaAnalysis_DataTemplate.xlsx"
CRITERIA_PDF="Copy of CardioProtect_MetaAnalysis_DataTemplate.pdf"

# Logging
LOG_LEVEL="INFO"

# Port for FastAPI
PORT=8000
